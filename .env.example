# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/returnkart

# Google OAuth2 (Gmail API)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend.replit.dev/api/email/callback

# Frontend URL (for post-OAuth redirect)
FRONTEND_URL=https://your-frontend.replit.dev
