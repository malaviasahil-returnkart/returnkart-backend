run = "bash start.sh"
entrypoint = "backend/main.py"
hidden = [".config", ".upm", ".gitignore", "__pycache__"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "${REPL_HOME}"

[deployment]
run = ["sh", "-c", "python backend/main.py"]
build = ["sh", "-c", "cd frontend && npm install && npm run build"]
