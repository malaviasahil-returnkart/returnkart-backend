run = "bash start.sh"
entrypoint = "backend/main.py"
hidden = [".config", ".upm", ".gitignore", "__pycache__"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "${REPL_HOME}"

[deployment]
# Creates venv if missing, installs deps into it, then runs the server.
# Nix store is immutable so pip must write to .venv, not system Python.
run = ["sh", "-c", "python3.10 -m venv .venv 2>/dev/null || true && .venv/bin/pip install -r backend/requirements.txt -q && .venv/bin/python backend/main.py"]
