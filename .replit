run = "bash start.sh"
entrypoint = "backend/main.py"
hidden = [".config", ".upm", ".gitignore", "__pycache__"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "${REPL_HOME}"

[deployment]
# .venv already exists with all deps installed. Just run directly.
# No pip needed — avoids Nix immutable store error.
run = [".venv/bin/python", "backend/main.py"]
