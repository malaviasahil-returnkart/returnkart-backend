run = "bash start.sh"
entrypoint = "backend/main.py"
hidden = [".config", ".upm", ".gitignore", "__pycache__"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "${REPL_HOME}"

[deployment]
# Build frontend first, then start backend which serves it as static files
run = ["sh", "-c", "cd frontend && npm install --silent && npm run build && cd .. && .venv/bin/python backend/main.py"]
