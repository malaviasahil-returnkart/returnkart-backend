run = "bash start.sh"
entrypoint = "backend/main.py"
hidden = [".config", ".upm", ".gitignore", "__pycache__"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "${REPL_HOME}"

[deployment]
# Phase 1: Python backend only. Frontend build added in Phase 2.
# Replit Autoscale uses a container (not Nix) so pip works normally.
run = ["sh", "-c", "pip install -r backend/requirements.txt -q && python backend/main.py"]
