run = "bash start.sh"
entrypoint = "backend/main.py"
hidden = [".config", ".upm", ".gitignore", "__pycache__"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "${REPL_HOME}"

[deployment]
# Use pip install with --target to write to a writable dir, bypassing Nix immutable store
run = ["sh", "-c", "pip install --target=/tmp/deps -r backend/requirements.txt -q && PYTHONPATH=/tmp/deps:$PYTHONPATH python backend/main.py"]
